---
import Layout from '../../components/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { siteSettings, blogPosts } from '../../lib/data';

export function getStaticPaths() {
  return blogPosts
    .filter(p => p.status === 'published' && p.slug)
    .map(p => ({ params: { slug: p.slug } }));
}

const { slug } = Astro.params;
const phone = siteSettings.phone;
const post = blogPosts.find(p => p.slug === slug);
if (!post) return Astro.redirect('/clubhouse/');

const title = `${post.title} | RAW Golf Academy`;
const description = post.excerpt;

const datePublished = new Date(post.date).toISOString().split('T')[0];
const articleSchema = {
  headline: post.title,
  datePublished,
  author: post.author,
};
---

<Layout title={title} description={description} article={articleSchema}>
  <Navbar phone={phone} activePage="clubhouse" />

  <div class="article-header">
    <div class="container article-narrow">
      <a href="/clubhouse/" class="article-back-link">&larr; Back to The Clubhouse</a>
      <p class="blog-card-date">{post.date} &bull; Golf Tips &bull; By {post.author}</p>
      <h1>{post.title}</h1>
    </div>
  </div>

  <article class="article-content">
    <div class="container article-narrow">
      <div class="article-hero">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" set:html={post.icon_svg || ''} />
      </div>

      <div set:html={post.body} />

      <div class="article-cta">
        <p class="article-cta-title">Ready to Work on Your Game?</p>
        <p class="article-cta-body">Book a lesson and get personalized instruction with real-time feedback on the GOLFZON simulator.</p>
        <a href={`tel:${phone}`} class="btn btn-gold">Book a Lesson</a>
      </div>
    </div>
  </article>

  <Footer
    phone={siteSettings.phone}
    phone_formatted={siteSettings.phone_formatted}
    location_name={siteSettings.location_name}
    location_address={siteSettings.location_address}
    hours={siteSettings.hours}
    first_timer_tips={siteSettings.first_timer_tips}
  />
</Layout>
