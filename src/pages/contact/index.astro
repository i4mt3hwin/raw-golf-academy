---
import Layout from '../../components/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import HoursList from '../../components/HoursList.astro';
import { siteSettings } from '../../lib/data';

const phone = siteSettings.phone;
const phoneFormatted = siteSettings.phone_formatted;
const locationName = siteSettings.location_name;
const locationAddress = siteSettings.location_address;
const hours = siteSettings.hours;

const title = 'Contact | RAW Golf Academy';
const description = 'Book a private golf lesson at RAW Golf Academy in Springfield, NJ. Call or text (973) 713-6462. Located inside GolfCube Social, open 9AM to 8PM daily.';
const mapEmbedUrl = 'https://www.google.com/maps?q=275+US-22,+Springfield,+NJ+07081&output=embed';
---

<Layout title={title} description={description}>
  <Navbar phone={phone} activePage="contact" />

  <div class="page-header text-center">
    <div class="container">
      <p class="section-label">Get in Touch</p>
      <h1>Contact Us</h1>
      <p>Ready to book a lesson or have a question? We'd love to hear from you.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div class="contact-intro">
          <h2>Call or Text to Get Started</h2>
          <p>Ready to book a lesson, ask about packages, or just have a question? Give us a call or send a text and we'll get you on the schedule.</p>

          <div class="phone-card">
            <div class="phone-card-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--color-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <a href={`tel:${phone}`} class="phone-card-number">{phoneFormatted}</a>
            <p class="phone-card-note">Call or Text, Monday through Sunday, 9AM to 8PM</p>
            <a href={`tel:${phone}`} class="btn btn-gold">Call Now</a>
          </div>
        </div>

        <div>
          <div class="location-row">
            <div class="footer-contact-icon">
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--color-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <p class="location-name">{locationName}</p>
              <p class="location-address">{locationAddress}</p>
            </div>
          </div>

          <div id="hours" class="hours-block">
            <h3 class="footer-card-title">Hours</h3>
            <HoursList hours={hours} />
          </div>

          <div class="map-container">
            <iframe src={mapEmbedUrl} allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="GolfCube Social location map"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer
    phone={siteSettings.phone}
    phone_formatted={siteSettings.phone_formatted}
    location_name={siteSettings.location_name}
    location_address={siteSettings.location_address}
    hours={siteSettings.hours}
    first_timer_tips={siteSettings.first_timer_tips}
  />
</Layout>
