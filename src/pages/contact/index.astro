---
import Layout from '../../components/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { siteSettings } from '../../lib/data';

const phone = siteSettings.phone;
const phoneFormatted = siteSettings.phone_formatted;
const locationName = siteSettings.location_name;
const locationAddress = siteSettings.location_address;
const hours = siteSettings.hours;

const title = 'Contact — RAW Golf Academy';
const description = 'Contact RAW Golf Academy at GolfCube Social, Springfield, NJ.';
const mapEmbedUrl = 'https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3024.0!2d-74.32!3d40.7!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x0%3A0x0!2sGolfCube+Social+Springfield+NJ!5e0!3m2!1sen!2sus!4v1';
---

<Layout title={title} description={description}>
  <Navbar phone={phone} activePage="contact" />

  <div class="page-header text-center">
    <div class="container">
      <p class="section-label">Get in Touch</p>
      <h1>Contact Us</h1>
      <p>Ready to book a lesson or have a question? We'd love to hear from you.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="contact-grid">
        <div>
          <h2 style="margin-bottom: 8px;">Call or Text to Get Started</h2>
          <p style="color: var(--color-text-light); margin-bottom: 32px;">Ready to book a lesson, ask about packages, or just have a question? Give us a call or send a text — we'll get you on the schedule.</p>

          <div style="background: var(--color-dark); border-radius: var(--radius-lg); padding: 40px; text-align: center;">
            <div style="width: 72px; height: 72px; border: 2px solid var(--color-gold); border-radius: var(--radius-md); display: flex; align-items: center; justify-content: center; margin: 0 auto 20px;">
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--color-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="width: 32px; height: 32px;"><path d="M22 16.92v3a2 2 0 0 1-2.18 2 19.79 19.79 0 0 1-8.63-3.07 19.5 19.5 0 0 1-6-6 19.79 19.79 0 0 1-3.07-8.67A2 2 0 0 1 4.11 2h3a2 2 0 0 1 2 1.72c.127.96.362 1.903.7 2.81a2 2 0 0 1-.45 2.11L8.09 9.91a16 16 0 0 0 6 6l1.27-1.27a2 2 0 0 1 2.11-.45c.907.338 1.85.573 2.81.7A2 2 0 0 1 22 16.92z"/></svg>
            </div>
            <a href={`tel:${phone}`} style="color: var(--color-gold); font-size: 2.5rem; font-weight: 800; display: block; margin-bottom: 8px;">{phoneFormatted}</a>
            <p style="color: #999; font-size: 0.9rem; margin-bottom: 24px;">Call or Text — Monday through Sunday, 9AM to 8PM</p>
            <a href={`tel:${phone}`} class="btn btn-gold">Call Now</a>
          </div>
        </div>

        <div>
          <div style="display: flex; align-items: center; gap: 16px; margin-bottom: 32px;">
            <div class="footer-contact-icon" style="border-color: var(--color-gold);">
              <svg viewBox="0 0 24 24" fill="none" stroke="var(--color-gold)" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"/><circle cx="12" cy="10" r="3"/></svg>
            </div>
            <div>
              <p style="color: var(--color-gold); font-weight: 700; font-size: 1.1rem;">{locationName}</p>
              <p style="font-size: 0.85rem; color: var(--color-text-muted);">{locationAddress}</p>
            </div>
          </div>

          <div id="hours" style="background: var(--color-dark); color: var(--color-white); border-radius: var(--radius-md); padding: 28px; margin-bottom: 24px;">
            <h3 class="footer-card-title">Hours</h3>
            <div class="hours-list">
              {hours.map((h) => (
                <div class="hours-row">
                  <span class="hours-day">{h.day}</span>
                  <span class="hours-time">{h.time}</span>
                </div>
              ))}
            </div>
          </div>

          <div class="map-container">
            <iframe src={mapEmbedUrl} allowfullscreen="" loading="lazy" referrerpolicy="no-referrer-when-downgrade" title="GolfCube Social location map"></iframe>
          </div>
        </div>
      </div>
    </div>
  </section>

  <Footer
    phone={siteSettings.phone}
    phone_formatted={siteSettings.phone_formatted}
    location_name={siteSettings.location_name}
    location_address={siteSettings.location_address}
    hours={siteSettings.hours}
    first_timer_tips={siteSettings.first_timer_tips}
  />
</Layout>
