---
import Layout from '../../components/Layout.astro';
import Navbar from '../../components/Navbar.astro';
import Footer from '../../components/Footer.astro';
import { siteSettings, proshopPhotos } from '../../lib/data';

const phone = siteSettings.phone;
const title = 'Pro Shop — Coming Soon — RAW Golf Academy';
const description = 'A preview of the RAW Golf Academy Pro Shop at GolfCube Social — opening soon with PING, Tour Edge, TaylorMade gear, custom fitting, and apparel.';
---

<Layout title={title} description={description}>
  <Navbar phone={phone} activePage="proshop" />

  <div class="page-header text-center">
    <div class="container">
      <p class="section-label">Opening Soon</p>
      <h1>Pro Shop <span class="text-gold-italic">Coming Soon</span></h1>
      <p>A peek at what's coming — PING and Tour Edge clubs, TaylorMade gloves, apparel, and custom fitting at GolfCube Social.</p>
    </div>
  </div>

  <section class="section">
    <div class="container">
      <div class="gallery-grid">
        {proshopPhotos.map((photo) => (
          <button type="button" class="gallery-item" onclick="openLightbox(this)" aria-label={`Open photo: ${photo.alt}`}>
            <img src={photo.src} alt={photo.alt} loading="lazy" width="800" height="533">
          </button>
        ))}
      </div>

      <div class="text-center mt-48">
        <p class="proshop-order-note">Want to know when the Pro Shop opens? Give us a call and we'll keep you posted.</p>
        <a href={`tel:${phone}`} class="btn btn-gold">Call to Get Updates</a>
      </div>
    </div>
  </section>

  <!-- Lightbox -->
  <div class="lightbox" id="lightbox" onclick="closeLightbox()">
    <button class="lightbox-close" aria-label="Close">&times;</button>
    <img id="lightboxImg" src="" alt="">
  </div>

  <Footer
    phone={siteSettings.phone}
    phone_formatted={siteSettings.phone_formatted}
    location_name={siteSettings.location_name}
    location_address={siteSettings.location_address}
    hours={siteSettings.hours}
    first_timer_tips={siteSettings.first_timer_tips}
  />
</Layout>
